// PilotOS — Schema Prisma
// PostgreSQL con schema "pilotos" dentro de BD compartida "nexos"
// Fecha: 2026-03-10
// Ref: PilotOS_Master.md, decisiones-tecnicas.md, introspeccion real

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["pilotos", "minos", "ledger"]
}

// ============================================
// MINOS — Tablas compartidas (solo lectura desde Prisma)
// Estas tablas las gestiona el ecosistema NexOS.
// PilotOS las referencia pero no las crea ni migra.
// ============================================

model MinosUser {
  id                     Int       @id @default(autoincrement())
  email                  String    @unique @db.VarChar(255)
  password_hash          String    @db.VarChar(255)
  role                   String?   @default("user") @db.VarChar(50)
  created_at             DateTime? @default(now()) @db.Timestamptz(6)
  updated_at             DateTime? @default(now()) @updatedAt @db.Timestamptz(6)
  google_access_token    String?
  google_refresh_token   String?
  google_token_expiry    BigInt?
  google_email           String?   @db.VarChar(255)
  gmail_connected        Boolean?  @default(false)
  forwarding_verified    Boolean?  @default(false)
  nombre                 String?   @db.VarChar(255)
  nif_cif                String?   @db.VarChar(50)
  stripe_customer_id     String?   @db.VarChar(100)
  stripe_subscription_id String?   @db.VarChar(100)
  cuota_mensual          Decimal?  @default(0.00) @db.Decimal(10, 2)
  estado_pago            String?   @default("AL DIA") @db.VarChar(20)
  fecha_bloqueo          DateTime? @db.Timestamp(6)
  telefono               String?   @db.VarChar(50)

  // Relaciones con PilotOS
  clientesPilotOS    Cliente[]
  conductoresPilotOS Conductor[]

  @@map("Users")
  @@schema("minos")
}

// ============================================
// LEDGER — Auditoria inmutable (solo escritura desde PilotOS)
// ============================================

model LedgerEvento {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tipo_evento   String    @db.VarChar(100)
  dedupe_key    String    @unique @db.VarChar(500)
  timestamp     DateTime? @default(now()) @db.Timestamptz(6)
  datos         Json
  estado        String?   @default("OK") @db.VarChar(20)
  source        String?   @default("UNKNOWN") @db.VarChar(50)
  error_message String?
  created_at    DateTime? @default(now()) @db.Timestamptz(6)

  @@index([dedupe_key], map: "idx_eventos_dedupe")
  @@index([timestamp(sort: Desc)], map: "idx_eventos_timestamp")
  @@index([tipo_evento], map: "idx_eventos_tipo")
  @@map("Eventos")
  @@schema("ledger")
}

// ============================================
// PILOTOS — CLIENTES (tenant key del producto)
// Un cliente es el titular de licencia / empresa.
// ============================================

model Cliente {
  id               String   @id @default(uuid())
  patron_id        Int // FK a minos.Users
  nombre_comercial String?
  tipo_actividad   String   @default("TAXI") // TAXI, VTC (futuro)
  activo           Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  // Relaciones
  patron                 MinosUser                @relation(fields: [patron_id], references: [id])
  vehiculos              Vehiculo[]
  conductores            Conductor[]
  configuracionEconomica ConfiguracionEconomica[]
  gastosFijos            GastoFijo[]
  cierresPeriodo         CierrePeriodo[]

  @@map("clientes")
  @@schema("pilotos")
}

// ============================================
// PILOTOS — CONDUCTORES
// Relacion entre un usuario minos y un cliente PilotOS.
// ============================================

model Conductor {
  id         String   @id @default(uuid())
  cliente_id String
  usuario_id Int // FK a minos.Users
  es_patron  Boolean  @default(false)
  activo     Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  // Relaciones
  cliente            Cliente                  @relation(fields: [cliente_id], references: [id])
  usuario            MinosUser                @relation(fields: [usuario_id], references: [id])
  vehiculosAsignados VehiculoConductor[]
  partesDiarios      ParteDiario[]
  anomalias          Anomalia[]
  configuraciones    ConfiguracionEconomica[]

  @@unique([cliente_id, usuario_id])
  @@map("conductores")
  @@schema("pilotos")
}

// ============================================
// PILOTOS — VEHICULOS
// ============================================

model Vehiculo {
  id                 String   @id @default(uuid())
  cliente_id         String
  matricula          String   @unique
  marca              String
  modelo             String
  fecha_matriculacion DateTime
  tipo_combustible   String // GASOLINA, DIESEL, HIBRIDO, ELECTRICO, GLP
  tipo_transmision   String // MANUAL, AUTOMATICA
  km_actuales        Int
  activo             Boolean  @default(true)
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  // Relaciones
  cliente        Cliente                 @relation(fields: [cliente_id], references: [id])
  conductores    VehiculoConductor[]
  partesDiarios  ParteDiario[]
  mantenimientos MantenimientoVehiculo[]
  gastosFijos    GastoFijo[]

  @@map("vehiculos")
  @@schema("pilotos")
}

model VehiculoConductor {
  id           String   @id @default(uuid())
  vehiculo_id  String
  conductor_id String
  activo       Boolean  @default(true)
  created_at   DateTime @default(now())

  vehiculo  Vehiculo  @relation(fields: [vehiculo_id], references: [id])
  conductor Conductor @relation(fields: [conductor_id], references: [id])

  @@unique([vehiculo_id, conductor_id])
  @@map("vehiculo_conductores")
  @@schema("pilotos")
}

// ============================================
// PILOTOS — CONFIGURACION ECONOMICA
// DT-006: Entidad propia, soporta multiples modelos.
// Se crea un registro vigente por cliente. Si cambia, se crea uno nuevo
// y el anterior se marca con fecha_fin.
// ============================================

model ConfiguracionEconomica {
  id                            String    @id @default(uuid())
  cliente_id                    String
  modelo_reparto                String    @default("PORCENTAJE") // PORCENTAJE, FIJO_DIARIO, PERSONALIZADO
  porcentaje_conductor          Decimal   @default(50) @db.Decimal(5, 2)
  porcentaje_patron             Decimal   @default(50) @db.Decimal(5, 2)
  cuota_pilotos                 Decimal   @default(0) @db.Decimal(10, 2) // Visible aunque bonificada a 0
  incluye_combustible_en_reparto Boolean   @default(true) // true = se descuenta antes de repartir
  notas                         String?
  conductor_id                  String? // Opcional: Especifica si la regla es para un conductor concreto
  fecha_inicio                  DateTime  @default(now())
  fecha_fin                     DateTime? // null = vigente
  activo                        Boolean   @default(true)
  created_at                    DateTime  @default(now())
  updated_at                    DateTime  @updatedAt

  // Relaciones
  cliente        Cliente        @relation(fields: [cliente_id], references: [id])
  conductor      Conductor?     @relation(fields: [conductor_id], references: [id])
  calculosPartes CalculoParte[]

  @@map("configuracion_economica")
  @@schema("pilotos")
}

// ============================================
// PILOTOS — PARTE DIARIO (MOTOR DEL SISTEMA)
// R-PD-*: Inmutable tras envio. Un parte por dia, conductor y vehiculo.
// ============================================

model ParteDiario {
  id               String   @id @default(uuid())
  fecha_trabajada  DateTime @db.Date
  fecha_envio      DateTime @default(now())
  vehiculo_id      String
  conductor_id     String
  km_inicio        Int
  km_fin           Int
  ingreso_bruto    Decimal  @db.Decimal(10, 2)
  ingreso_datafono Decimal  @db.Decimal(10, 2)
  combustible      Decimal? @db.Decimal(10, 2)
  varios           Decimal? @db.Decimal(10, 2)
  concepto_varios  String? // Obligatorio si varios > 0
  estado           String   @default("ENVIADO") // BORRADOR, ENVIADO, FOTO_SUSTITUIDA
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  // Relaciones
  vehiculo   Vehiculo        @relation(fields: [vehiculo_id], references: [id])
  conductor  Conductor       @relation(fields: [conductor_id], references: [id])
  documentos DocumentoEnlace[]
  incidencias Incidencia[]
  calculo    CalculoParte?

  // Un parte por vehiculo y dia
  @@unique([vehiculo_id, fecha_trabajada])
  @@map("partes_diarios")
  @@schema("pilotos")
}

// ============================================
// PILOTOS — CALCULOS DE PARTE (DT-007)
// Derivado del parte + configuracion economica vigente.
// Separado del parte porque el parte es inmutable.
// ============================================

model CalculoParte {
  id                            String   @id @default(uuid())
  parte_diario_id               String   @unique
  configuracion_id              String
  bruto_diario                  Decimal  @db.Decimal(10, 2)
  combustible                   Decimal  @default(0) @db.Decimal(10, 2)
  neto_diario                   Decimal  @db.Decimal(10, 2)
  varios                        Decimal  @default(0) @db.Decimal(10, 2)
  parte_conductor               Decimal  @db.Decimal(10, 2)
  parte_patron                  Decimal  @db.Decimal(10, 2)
  modelo_reparto_aplicado       String
  porcentaje_conductor_aplicado Decimal  @db.Decimal(5, 2)
  porcentaje_patron_aplicado    Decimal  @db.Decimal(5, 2)
  created_at                    DateTime @default(now())

  // Relaciones
  parteDiario   ParteDiario            @relation(fields: [parte_diario_id], references: [id])
  configuracion ConfiguracionEconomica @relation(fields: [configuracion_id], references: [id])

  @@map("calculos_partes")
  @@schema("pilotos")
}

// ============================================
// PILOTOS — DOCUMENTOS (DT-008)
// Modelo documental generico con hash, deduplicacion y vinculo a Drive.
// Reemplaza FotoTicket del schema legacy.
// ============================================

model Documento {
  id                    String              @id @default(uuid())
  tipo                  String // TICKET_TAXIMETRO, TICKET_COMBUSTIBLE, FACTURA, RECIBO, FOTO, PDF, OTRO
  url                   String // URL local o Drive
  drive_file_id         String? // ID en Google Drive, si aplica
  hash_sha256           String? // Hash para deduplicacion
  estado                String              @default("RECIBIDO") // RECIBIDO, VALIDO, ILEGIBLE, REEMPLAZADO, BLOQUEADO
  ocr_texto             String?
  ocr_confianza         Float?
  ocr_datos_extraidos   Json? // Datos estructurados del OCR (importe, fecha, litros, etc.)
  intentos_reemplazo    Int                 @default(0)
  subido_por_usuario_id Int? // FK a minos.Users (quien subio el doc)
  created_at            DateTime            @default(now())
  updated_at            DateTime            @updatedAt
  enlaces               DocumentoEnlace[]
  historial             DocumentoHistorial[]

  @@map("documentos")
  @@schema("pilotos")
}

model DocumentoEnlace {
  id           String   @id @default(uuid())
  documento_id String
  entidad_tipo String // PARTE_DIARIO, GASTO, MANTENIMIENTO, VEHICULO, CONDUCTOR
  entidad_id   String // UUID de la entidad vinculada
  created_at   DateTime @default(now())

  // Relaciones
  documento   Documento    @relation(fields: [documento_id], references: [id])
  parteDiario ParteDiario? @relation(fields: [entidad_id], references: [id], map: "doc_enlace_parte_fk")

  @@unique([documento_id, entidad_tipo, entidad_id])
  @@map("documento_enlaces")
  @@schema("pilotos")
}

model DocumentoHistorial {
  id           String   @id @default(uuid())
  documento_id String
  url_anterior String
  motivo       String
  created_at   DateTime @default(now())

  documento Documento @relation(fields: [documento_id], references: [id])

  @@map("documento_historial")
  @@schema("pilotos")
}

// ============================================
// PILOTOS — TAREAS PENDIENTES
// ============================================

model TareaPendiente {
  id           String    @id @default(uuid())
  tipo         String // FOTO_ILEGIBLE, DATO_FALTANTE, etc.
  entidad_tipo String // PARTE_DIARIO, DOCUMENTO, etc.
  entidad_id   String
  conductor_id String
  resuelta     Boolean   @default(false)
  created_at   DateTime  @default(now())
  resolved_at  DateTime?

  @@map("tareas_pendientes")
  @@schema("pilotos")
}

// ============================================
// PILOTOS — ANOMALIAS
// R-AN-*: Se acumulan, NUNCA se resetean.
// ============================================

model Anomalia {
  id           String   @id @default(uuid())
  conductor_id String
  tipo         String // NORMAL, CRITICA
  descripcion  String
  notificada   Boolean  @default(false)
  created_at   DateTime @default(now())

  conductor Conductor @relation(fields: [conductor_id], references: [id])

  @@map("anomalias")
  @@schema("pilotos")
}

// ============================================
// PILOTOS — INCIDENCIAS
// R-IN-*: Solo via GlorIA, solo patron autoriza.
// ============================================

model Incidencia {
  id              String    @id @default(uuid())
  parte_diario_id String
  que_ocurrio     String
  decision_tomada String
  justificacion   String
  autorizador_id  String // conductor_id del patron
  estado          String    @default("CREADA") // CREADA, CERRADA
  created_at      DateTime  @default(now())
  closed_at       DateTime?

  parteDiario ParteDiario @relation(fields: [parte_diario_id], references: [id])

  @@map("incidencias")
  @@schema("pilotos")
}

// ============================================
// PILOTOS — GASTOS
// ============================================

model Gasto {
  id          String   @id @default(uuid())
  cliente_id  String // Tenant key
  vehiculo_id String?
  tipo        String // COMBUSTIBLE, MANTENIMIENTO, SEGURO, AUTONOMO, GESTORIA, EMISORA, IGIC, IRPF, VARIOS
  descripcion String
  importe     Decimal  @db.Decimal(10, 2)
  fecha       DateTime @db.Date
  forma_pago  String? // EFECTIVO, TARJETA, TRANSFERENCIA, DOMICILIACION
  url_factura String?
  estado      String   @default("REGISTRADO") // RECIBIDO, CLASIFICADO, PENDIENTE_CONFIRMACION, REGISTRADO
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@map("gastos")
  @@schema("pilotos")
}

model GastoFijo {
  id           String   @id @default(uuid())
  cliente_id   String
  vehiculo_id  String?
  tipo         String // AUTONOMO, SEGURO, EMISORA, IMPUESTO, OTRO
  descripcion  String
  importe      Decimal  @db.Decimal(10, 2)
  periodicidad String // MENSUAL, TRIMESTRAL, ANUAL
  activo       Boolean  @default(true)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  cliente  Cliente   @relation(fields: [cliente_id], references: [id])
  vehiculo Vehiculo? @relation(fields: [vehiculo_id], references: [id])

  @@map("gastos_fijos")
  @@schema("pilotos")
}

// ============================================
// PILOTOS — MANTENIMIENTOS
// R-MT-*: Catalogo cerrado, frecuencia aprendible.
// ============================================

model MantenimientoCatalogo {
  id               String   @id @default(uuid())
  nombre           String   @unique
  tipo             String // POR_KILOMETRAJE, SEGUN_USO, POR_FECHA
  frecuencia_km    Int?
  frecuencia_meses Int?
  activo           Boolean  @default(true)
  created_at       DateTime @default(now())

  vehiculos MantenimientoVehiculo[]

  @@map("mantenimiento_catalogo")
  @@schema("pilotos")
}

model MantenimientoVehiculo {
  id                     String    @id @default(uuid())
  vehiculo_id            String
  catalogo_id            String
  ultima_ejecucion_km    Int?
  ultima_ejecucion_fecha DateTime?
  proximo_km             Int?
  proxima_fecha          DateTime?
  estado                 String    @default("PENDIENTE") // PENDIENTE, VENCIDO, RESUELTO
  frecuencia_aprendida   Int?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  vehiculo Vehiculo              @relation(fields: [vehiculo_id], references: [id])
  catalogo MantenimientoCatalogo @relation(fields: [catalogo_id], references: [id])

  // Seguimiento historico
  seguimiento SeguimientoMantenimiento[]

  @@unique([vehiculo_id, catalogo_id])
  @@map("mantenimientos_vehiculos")
  @@schema("pilotos")
}

// ============================================
// PILOTOS — SEGUIMIENTO DE MANTENIMIENTO
// Historial de acciones sobre cada mantenimiento.
// ============================================

model SeguimientoMantenimiento {
  id                        String   @id @default(uuid())
  mantenimiento_vehiculo_id String
  accion                    String // RESUELTO, VENCIDO, FRECUENCIA_ACTUALIZADA, AVISO_ENVIADO
  detalle                   String?
  km_en_momento             Int?
  created_at                DateTime @default(now())

  mantenimientoVehiculo MantenimientoVehiculo @relation(fields: [mantenimiento_vehiculo_id], references: [id])

  @@map("seguimiento_mantenimiento")
  @@schema("pilotos")
}

// ============================================
// PILOTOS — AVISOS
// ============================================

model Aviso {
  id           String    @id @default(uuid())
  cliente_id   String
  tipo         String // MANTENIMIENTO, VENCIMIENTO, ANOMALIA, SISTEMA
  titulo       String
  mensaje      String
  entidad_tipo String? // Referencia a la entidad relacionada
  entidad_id   String?
  leido        Boolean   @default(false)
  enviado      Boolean   @default(false)
  enviado_at   DateTime?
  created_at   DateTime  @default(now())

  @@map("avisos")
  @@schema("pilotos")
}

// ============================================
// PILOTOS — CIERRES DE PERIODO
// Liquidaciones mensuales o por rango.
// ============================================

model CierrePeriodo {
  id                    String   @id @default(uuid())
  cliente_id            String
  periodo_inicio        DateTime @db.Date
  periodo_fin           DateTime @db.Date
  total_bruto           Decimal  @db.Decimal(10, 2)
  total_combustible     Decimal  @db.Decimal(10, 2)
  total_neto            Decimal  @db.Decimal(10, 2)
  total_gastos_fijos    Decimal  @db.Decimal(10, 2)
  total_gastos_variables Decimal  @db.Decimal(10, 2)
  total_conductor       Decimal  @db.Decimal(10, 2)
  total_patron          Decimal  @db.Decimal(10, 2)
  cuota_pilotos         Decimal  @db.Decimal(10, 2)
  num_partes            Int
  estado                String   @default("BORRADOR") // BORRADOR, CERRADO, PDF_GENERADO
  pdf_url               String?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  cliente Cliente @relation(fields: [cliente_id], references: [id])

  @@map("cierres_periodo")
  @@schema("pilotos")
}

// ============================================
// PILOTOS — ONBOARDING
// Datos temporales del flujo de registro.
// Se usa durante el onboarding y luego se archiva.
// ============================================

model Onboarding {
  id                  String    @id @default(uuid())
  telefono            String    @unique
  completado          Boolean   @default(false)
  nombre_patron       String?
  email_patron        String?
  nif_cif             String?
  nombre_comercial    String?
  tipo_actividad      String? // TAXI, VTC
  asalariados         Json? // [{ nombre, telefono, modelo_reparto, porcentaje_conductor }]
  gastos_fijos        Json? // [{ descripcion, importe, periodicidad }]
  matricula           String?
  marca_modelo        String?
  fecha_matriculacion DateTime?
  tipo_combustible    String?
  tipo_transmision    String?
  km_actuales         Int?
  seguro_vigencia     DateTime?
  preferencias_avisos Json?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  @@map("onboarding")
  @@schema("pilotos")
}
