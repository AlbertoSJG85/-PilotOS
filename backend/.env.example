# PilotOS Backend — Variables de entorno
# Copiar a .env y rellenar con valores reales

# Servidor
PORT=3001
NODE_ENV=production

# Base de datos PostgreSQL (BD compartida nexos, schema pilotos)
DATABASE_URL="postgresql://USER:PASSWORD@161.97.108.106:5433/nexos?schema=pilotos"

# Auth (compartido con ecosistema NexOS — NO usar fallbacks)
JWT_SECRET=

# Comunicacion interna entre productos (GlorIA → PilotOS)
INTERNAL_API_TOKEN=

# CORS — origenes permitidos en produccion (separados por coma)
ALLOWED_ORIGINS=https://pilotos.nexostudios.digital

# n8n (orquestacion de workflows)
N8N_WEBHOOK_URL=https://n8n.nexostudios.digital/webhook

# Storage (fase 1: local, futuro: S3-compatible)
# MINIO_ENDPOINT=
# MINIO_PORT=
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=
# MINIO_BUCKET=pilotos-fotos
